                {
                  "type": "text",
                  "id": "xp5HR",
                  "fill": "#444444",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Lempel-Ziv-Welch (LZW) is a dictionary-based algorithm. Instead of analyzing character frequencies up front, it dynamically builds a dictionary of repeating sequences as it scans the file. It's the foundational algorithm behind formats like GIF and TIFF.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
