                {
                  "type": "text",
                  "id": "M6Bvq",
                  "fill": "#444444",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "By traversing the tree from the root to the leaf node, we generate the binary code for each character. Since no leaf is an ancestor of another, it guarantees that no code is a prefix of another, allowing unambiguous decoding.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "sQG6E",
